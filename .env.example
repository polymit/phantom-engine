# .env.example — Phantom Engine environment variables
# Copy to .env and fill in values. NEVER commit .env to git.

# Required
# API key for MCP connections (X-API-Key header)
# Generate: openssl rand -hex 32
PHANTOM_API_KEY=your-api-key-here

# Snapshot signing key
# Generate: openssl rand -hex 32
PHANTOM_SNAPSHOT_KEY=your-snapshot-key-here

# Optional (defaults shown)
# Network binding
PHANTOM_BIND_ADDR=0.0.0.0:8080

# Storage directory (must be writable by the phantom user)
PHANTOM_STORAGE_DIR=/data/storage

# Log format: json (production) | pretty (development) | compact
PHANTOM_LOG_FORMAT=json

# Log level (RUST_LOG format)
RUST_LOG=phantom=info,tower_http=warn

# Session limits
PHANTOM_SESSION_LIMIT=1000
PHANTOM_RATE_LIMIT=100

# JS engine tier ratios
PHANTOM_QUICKJS_POOL_SIZE=10
PHANTOM_V8_POOL_SIZE=5

# Grafana credentials (docker-compose only)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# Prometheus fingerproxy sidecar (CI only)
# FINGERPROXY_BIND=localhost:8443
