# .env.example — Phantom Engine environment variables
# Copy to .env and fill in values. Never commit .env.

# Required
PHANTOM_API_KEY=your-api-key-here

# Optional defaults
PHANTOM_BIND_ADDR=0.0.0.0:8080
PHANTOM_STORAGE_DIR=/data/storage
PHANTOM_LOG_FORMAT=json
RUST_LOG=phantom=info,tower_http=warn

# Session limits (Section 11)
PHANTOM_SESSION_LIMIT=1000
PHANTOM_RATE_LIMIT=100

# Pool sizes
PHANTOM_QUICKJS_POOL_SIZE=10
PHANTOM_V8_POOL_SIZE=5

# Grafana credentials (docker-compose only)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production
